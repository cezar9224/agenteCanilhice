<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="40dp"
    android:paddingEnd="28dp"
    android:paddingBottom="30dp">

    <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="0.35" />

    <TextView
        android:id="@+id/appNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.08"
        android:text="@string/app_name"
        android:textColor="@color/cream"
        android:textSize="34sp" />

    <FrameLayout
        android:layout_width="260dp"
        android:layout_height="260dp">

        <View
            android:id="@+id/robotGlow"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:alpha="0.28"
            android:background="@drawable/robot_glow" />

        <ImageView
            android:id="@+id/robotImage"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:contentDescription="@string/robot_description"
            android:src="@drawable/ic_robot" />
    </FrameLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="52dp"
        android:text="@string/status_ready"
        android:textColor="@color/cream"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="3"
        android:textColor="#A9BAC7"
        android:textSize="14sp"
        android:visibility="gone" />

    <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="0.65" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/apiKeyLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/api_key_hint"
        app:boxBackgroundColor="@color/slate"
        app:boxStrokeColor="@color/teal"
        app:endIconMode="password_toggle"
        app:hintTextColor="#A9BAC7">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:importantForAutofill="no"
            android:inputType="textPassword"
            android:maxLines="1"
            android:textColor="@color/cream" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/listenButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="18dp"
        android:text="@string/listen"
        android:textSize="17sp"
        android:textStyle="bold"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_mic"
        app:iconGravity="textStart"
        app:iconPadding="12dp" />

</LinearLayout>
